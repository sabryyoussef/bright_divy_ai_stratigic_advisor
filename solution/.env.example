# Copy to `.env` locally (never commit real secrets).
# Used by FastAPI analytics container / local uvicorn.

# Docker warehouse (host maps container 5432 -> host 55432 in docker-compose.yml)
DATABASE_URL=postgresql://warehouse:warehouse_dev_change_me@127.0.0.1:55432/warehouse

# WSL Postgres alternative (if you used solution/wsl/bootstrap-warehouse.sh):
